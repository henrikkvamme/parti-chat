{
  "name": "parti-chat",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "biome check --write .",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F server db:push",
    "db:studio": "turbo -F server db:studio",
    "db:generate": "turbo -F server db:generate",
    "db:migrate": "turbo -F server db:migrate",
    "db:start": "turbo -F server db:start",
    "db:watch": "turbo -F server db:watch",
    "db:stop": "turbo -F server db:stop",
    "db:down": "turbo -F server db:down",
    "start:server": "turbo -F server start",
    "start": "turbo start"
  },
  "dependencies": {
    "pdfjs-dist": "^5.4.149",
    "react-pdf": "^10.1.0",
    "uuid": "^11.1.1"
  },
  "overrides": {
    "kysely": ">=0.28.17",
    "defu": ">=6.1.5",
    "lodash": ">=4.17.23",
    "lodash-es": ">=4.17.23",
    "devalue": ">=5.6.2",
    "dompurify": ">=3.2.7",
    "mermaid": ">=11.15.0",
    "preact": ">=10.27.3",
    "tar": ">=7.5.7",
    "qs": ">=6.15.2",
    "path-to-regexp": ">=8.4.0",
    "minimatch": ">=10.2.1",
    "brace-expansion": ">=2.0.3",
    "@isaacs/brace-expansion": ">=5.0.1",
    "postcss": ">=8.5.10",
    "esbuild": ">=0.25.0",
    "vite": ">=7.1.5",
    "rollup": ">=4.59.0",
    "yaml": ">=2.8.3",
    "js-yaml": ">=4.1.1",
    "glob": ">=10.5.0",
    "ip-address": ">=10.2.0",
    "langsmith": ">=0.4.6",
    "@langchain/core": ">=0.3.80 <0.4.0",
    "picomatch": ">=4.0.4",
    "diff": ">=8.0.3",
    "ajv": ">=6.14.0",
    "body-parser": ">=2.2.1",
    "handlebars": ">=4.7.9",
    "mdast-util-to-hast": ">=13.2.1",
    "prismjs": ">=1.30.0",
    "@trpc/server": ">=11.8.0",
    "@modelcontextprotocol/sdk": ">=1.25.2",
    "vitest": ">=3.2.6",
    "uuid": ">=11.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "@types/uuid": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "turbo": "^2.9.14",
    "ultracite": "5.2.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite format"
    ]
  },
  "packageManager": "bun@1.2.21"
}
